{
  "manifest_version": 3,
  "name": "Selection Popup Assistant",
  "version": "1.1",
  "description": "Mouse ile metin seçildiğinde beliren, Gemini destekli premium chat asistanı.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
